{
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "functions": {
    "api/*.js": { "runtime": "nodejs20.x" }
  },
  "crons": [
    { "path": "/api/push-morning", "schedule": "0 * * * *" },
    { "path": "/api/push-evening", "schedule": "0 * * * *" },
    { "path": "/api/push-winddown", "schedule": "0 * * * *" }
  ]
}
