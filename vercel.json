{
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "crons": [
    { "path": "/api/push-scheduled?type=morning", "schedule": "0 12 * * *" },
    { "path": "/api/push-scheduled?type=evening", "schedule": "0 2 * * *" },
    { "path": "/api/push-weekly", "schedule": "0 19 * * 0" }
  ]
}
